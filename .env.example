# ── Clerk ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Sign-in/up pages live on Famalii Core, not here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://famalii-core.vercel.app/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://famalii-core.vercel.app/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Satellite domain — tells Clerk to do a cross-domain token handshake with famalii-core
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_DOMAIN=famalii-legal.vercel.app  # update if custom domain added

# Cross-app linking
NEXT_PUBLIC_FAMALII_CORE_URL=https://famalii-core.vercel.app
